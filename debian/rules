#!/usr/bin/make -f
include /usr/share/dpkg/default.mk
export QT_SELECT = qt6
VERSION = $(DEB_VERSION_UPSTREAM)
PACK_VER = $(shell echo $(VERSION) | awk -F'[+_~-]' '{print $$1}')
%:
	dh $@ --parallel
override_dh_auto_configure:
	export DEB_CFLAGS_MAINT_APPEND="-fstack-protector-all -Wall -Wl,--as-needed -Wl,-E"
	export DEB_CXXFLAGS_MAINT_APPEND="-fstack-protector-all -Wall -Wl,--as-needed -Wl,-E"
	export DEB_LDFLAGS_MAINT_APPEND="-z relro -z now -z noexecstack"
	dh_auto_configure -- -DCVERSION=$(DEB_VERSION_UPSTREAM) -DDVERSION=$(PACK_VER) -DUSE_DEEPIN_ZONE=ON
